amends "package://github.com/jdx/hk/releases/download/v1.48.0/hk@1.48.0#/Config.pkl"

// hk git hooks (replaces lefthook.yml) — https://hk.jdx.dev
//
// pre-commit auto-fixes formatting then linting (formatting can affect lint
// output); pre-push is the final gate (format-check, clippy, tests, coverage).
// cargo fmt/clippy operate on the whole workspace, so the *.rs glob only gates
// *whether* a step runs — the commands take no file arguments. `depends`
// serialises the steps within each hook.
//
// git invokes hooks with GIT_DIR (and friends) exported, and git honours those
// over a `-C <dir>` argument. The suite spawns real `git` against throwaway temp
// repos, so the test/coverage steps strip the inherited GIT_* location variables
// first — otherwise those subprocesses would target this repo instead of their
// sandboxes. (`run_git` in src/testutil.rs scrubs the same set as defence in
// depth.)

hooks {
  // Reject commit messages that aren't Conventional Commits (enforced with
  // convco via a mise task). {{commit_msg_file}} is the path git passes to the
  // commit-msg hook.
  ["commit-msg"] {
    steps = new Mapping<String, Step> {
      ["convco"] {
        check = "mise run commit-msg-check {{commit_msg_file}}"
      }
    }
  }
  ["pre-commit"] {
    fix = true
    stash = "git"
    steps = new Mapping<String, Step> {
      ["format"] {
        glob = "*.rs"
        fix = "mise run format"
      }
      ["lint-fix"] {
        glob = "*.rs"
        depends = List("format")
        fix = "mise run lint-fix"
      }
    }
  }
  ["pre-push"] {
    fix = false
    steps = new Mapping<String, Step> {
      ["format-check"] {
        check = "mise run format-check"
      }
      ["lint"] {
        depends = List("format-check")
        check = "mise run lint"
      }
      ["test"] {
        depends = List("lint")
        check = "mise run test"
      }
      ["commit-check"] {
        check = "mise run commit-check"
      }
    }
  }
}
